# Copy to .env for local dev. Override for production via .env.production.

# -------- Django --------
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-for-local-dev-only-do-not-reuse-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8000

# -------- Postgres --------
POSTGRES_DB=labreport
POSTGRES_USER=labreport
POSTGRES_PASSWORD=labreport
DATABASE_URL=postgres://labreport:labreport@postgres:5432/labreport

# -------- Redis / Celery --------
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=django-db
CELERY_TASK_ALWAYS_EAGER=False

# -------- CORS --------
CORS_ALLOWED_ORIGINS=http://localhost:5173

# -------- Frontend --------
VITE_API_BASE_URL=/api

# -------- Sentry (optional) --------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
